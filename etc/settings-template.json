{
    "log": {
        "level" : "debug",
        "console" : true,
        "maxsize": 10000000,
        "maxFiles": 10,
        "filename" : "server.log"
    },
    "server" : {
        "bindAddress": "0.0.0.0",
        "listenPort" : "$PORT",
        "middlewares": {
            "bo": {
                "dir": "../vendor/bo",
                "prefix": "/bo/",
                "db" : {
                    "host": "$DB_HOST",
                    "port": "$DB_PORT",
                    "user": "$DB_USER",    
                    "password": "$DB_PASSWORD"
                },
                "apiKey": "$API_KEY",
                "defaultApp": "viewModel_navbar_flower",
                "defaultTab": "account"

            },
            "core": {
                "dir": "../vendor/flCore",
                "prefix": "/core/",
                "db" : {
                    "host": "$DB_HOST",
                    "port": "$DB_PORT",
                    "user": "$DB_USER",    
                    "password": "$DB_PASSWORD"
                },
                "encrypt" : {
                    "secret": "$ENCRYPT_SECRET",
                    "iv": "$ENCRYPT_IV"
                },
                "apiKey": "$API_KEY",
                "fileStorage": "../../fileStorage",
                "smtp": {
                    "smtpServer": "$SMTP_SERVER",
                    "smtpPort": "$SMTP_PORT",
                    "smtpSecure": true,
                    "smtpUser": "$SMTP_USER",
                    "smtpPassword": "$SMTP_PASSWORD",
                    "from": "DC contact@flow-er.fr"
                },
                "imap": {
                    "imapServer": "$IMAP_SERVER",
                    "imapPort": "$IMAP_PORT",
                    "imapUser": "$IMAP_USER",
                    "imapPassword": "$IMAP_PASSWORD"
                },
                "sms": {
                    "apiKey": "$API_KEY",
                    "apiSecret": "$API_SECRET",
                    "sender": "Max DC",
                    "sandbox": 1
                }
            },
            "doc": {
                "dir": "../vendor/doc",
                "prefix": "/doc/",
                "db" : {
                    "host": "$DB_HOST",
                    "port": "$DB_PORT",
                    "user": "$DB_USER",    
                    "password": "$DB_PASSWORD"
                }
            },
            "mdb": {
                "dir": "../vendor/mdb",
                "prefix": "/mdb/",
                "db" : {
                    "host": "$DB_HOST",
                    "port": "$DB_PORT",
                    "user": "$DB_USER",    
                    "password": "$DB_PASSWORD"
                }
            },
            "document": {
                "dir": "../vendor/document",
                "prefix": "/document/",
                "db" : {
                    "host": "$DB_HOST",
                    "port": "$DB_PORT",
                    "user": "$DB_USER",    
                    "password": "$DB_PASSWORD"
                }
            },
            "hub": {
                "dir": "../vendor/hub",
                "prefix": "/hub/",
                "db" : {
                    "host": "$DB_HOST",
                    "port": "$DB_PORT",
                    "user": "$DB_USER",    
                    "password": "$DB_PASSWORD"
                },
                "smtp": {
                    "smtpServer": "$SMTP_SERVER",
                    "smtpPort": "$SMTP_PORT",
                    "smtpSecure": true,
                    "smtpUser": "$SMTP_USER",
                    "smtpPassword": "$SMTP_PASSWORD"
                },
                "apiKey": "$API_KEY",
                "tokenPayloadModel": {
                    "entity": "profile",
                    "user_id": "user_id",
                    "columns": ["n_first", "n_last", "n_fn", "email", "equipe", "role"]
                },
                "sms": {
                    "apiKey": "$API_KEY",
                    "apiSecret": "$API_SECRET",
                    "sender": "Max DC",
                    "sandbox": 1
                }
            },
            "my": {
                "dir": "../vendor/my",
                "prefix": "/my/",
                "db" : {
                    "host": "$DB_HOST",
                    "port": "$DB_PORT",
                    "user": "$DB_USER",    
                    "password": "$DB_PASSWORD"
                }
            },
            "pub": {
                "dir": "../vendor/pub",
                "prefix": "/pub/",
                "db" : {
                    "host": "$DB_HOST",
                    "port": "$DB_PORT",
                    "user": "$DB_USER",    
                    "password": "$DB_PASSWORD"
                },
                "recaptchaToken": "$RECAPTCHA_TOKEN"
            },
            "studio": {
                "dir": "../vendor/studio",
                "prefix": "/studio/",
                "db" : {
                    "host": "$DB_HOST",
                    "port": "$DB_PORT",
                    "user": "$DB_USER",    
                    "password": "$DB_PASSWORD"
                }
            },
            "user": {
                "dir": "../vendor/user",
                "prefix": "/user/",
                "db" : {
                    "host": "$DB_HOST",
                    "port": "$DB_PORT",
                    "user": "$DB_USER",    
                    "password": "$DB_PASSWORD"
                },
                "smtp": {
                    "smtpServer": "$SMTP_SERVER",
                    "smtpPort": "$SMTP_PORT",
                    "smtpSecure": true,
                    "smtpUser": "$SMTP_USER",
                    "smtpPassword": "$SMTP_PASSWORD",
                    "to": "bruno@p-pit.fr"
                },
                "tokenExpirationTime": "$TOKEN_EXPIRATION_TIME",
                "cookieDomain": "$COOKIE_DOMAIN",
                "cookieSecure": false,
                "cookieHttpOnly": false,
                "apiUserId": "$API_USER_ID",
                "apiUserPassword": "$API_USER_PASSWORD",
                "apiKey": "$API_KEY",
                "tokenPayloadModel": {
                    "entity": "crm_profile",
                    "columns": { "id": "profile_id", "n_fn": "n_fn", "place_id": "place_id", "role": "role", "theme": "theme" },
                    "model": "crm_profile/model"
                }
            }
       },
        "config": {
            "dir": "../config",
            "dbName": "$DB_NAME",
            "current": []
        }
    }
}